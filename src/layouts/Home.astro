---
import Sidebar from "../components/Sidebar.astro";
import { SITE_TITLE ,SITE_DESCRIPTION, SITE_MENU, SITE_CREDIT , TRACKING_ID, BASE_URL } from "../consts";

import Bars from './../../public/img/bars.svg';

interface Props{
  og_site_name?:string;
  og_title?:string;
  og_description?:string;
  og_url?:string;
  og_image?:string;
  og_type?:string;
  og_locale?:string;
}

const { og_site_name,og_title,og_description,og_url,og_image,og_type,og_locale }=Astro.props;
const has_ogp:boolean=og_site_name||og_title||og_description||og_url||og_image||og_type||og_locale?true:false;
---

<head prefix={has_ogp?"og: https://ogp.me/ns#":""} data-TrackingID={TRACKING_ID}>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Type" content="text/html;charset=UTF-8">
  <meta lang="ja">
  <meta name="google-site-verification" content="CT-CN4TbnrtfjHjN6Oe3NKMewseQjDWf3EkBK6O24Ko" />
  {og_url?<meta property="og:url" content={og_url} />:null}
  {og_type?<meta property="og:type" content={og_type} />:null}
  <meta property="og:title" content={og_title||SITE_TITLE} />
  <meta property="og:image" content={og_image||BASE_URL+"img/RPC.png"} />
  {og_site_name?<meta property="og:site_name" content={og_site_name} />:null}
  {og_description?<meta property="og:description" content={og_description} />:null}
  {og_locale?<meta property="og:locale" content={og_locale} />:null}
  {has_ogp?<meta name="twitter:card" content="summary_large_image" /><meta name="twitter:title" content={og_title} /><meta name="twitter:description" content={og_description||SITE_DESCRIPTION} /><meta name="twitter:image" content={og_image||BASE_URL+"img/RPC.png"} /><meta name="twitter:site" content="@RokkoPhysics" />:null}
  <title>{SITE_TITLE}</title>
  <script is:inline>
    const theme = localStorage.getItem('theme') ?? '';

    document.documentElement.style.setProperty('color-scheme', theme);
      
    switch(theme) {
      case "light":
        document.documentElement.style.setProperty('--theme-highlight-left', `${0.25}rem`);
        break;
      case "dark":
        document.documentElement.style.setProperty('--theme-highlight-left', `${0.25 + 2.75}rem`);
        break;
      case "":
        document.documentElement.style.setProperty('--theme-highlight-left', `${0.25 + 2.75 * 2}rem`);
        break;
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet">
  <link rel="icon" sizes="48x48" href="/favicon.ico">
  <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="mobile-web-app-capable" content="yes">
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${TRACKING_ID}`}></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', document.head.dataset.trackingid);
  </script>
</head>
<body>
  <div id="main-wrapper">
    <div id="sidebar-wrapper">
      <Sidebar  title={SITE_TITLE} title_desc={SITE_DESCRIPTION} links={SITE_MENU} credit={SITE_CREDIT} />
    </div>
    <button id="menu-button" onpointerdown="document.getElementById('sidebar-wrapper').classList.toggle('active');this.classList.toggle('active')">
      <Bars></Bars>
      Menu
    </button>
    <div id="content-wrapper">
      <slot/>
    </div>
  </div>
</body>

<style is:global>
:root {
  color-scheme: light dark;
  --background: light-dark(#eee, #303030);
  --on-background: light-dark(#333, #eee);
  --surface-highest: light-dark(#ffffff, #3f3f3f);
  --surface-high: light-dark(#fbfbfb, #3b3b3b);
  --surface: light-dark(#f8f8f8, #383838);
  --surface-low: light-dark(#f4f4f4, #343434);
  --surface-lowest: light-dark(#f0f0f0, #303030);
  --on-surface: light-dark(#333, #eee);
  --on-surface-variant: light-dark(#555, #ccc);
  --outline: light-dark(#ccc, #555);
  --outline-variant: light-dark(#777, #aaa);
  --primary: light-dark(#2472b6, #4293da);
  --primary-container: light-dark(#53a0e4, #498fcc);
  --warn: light-dark(#fa4, #fa4);
  --warn-container: light-dark(#ffe8a1, #7c6b39);
  --error: light-dark(#f44, #f44);
  --error-container: light-dark(#ffc3c3, #884747);
  --shadow: light-dark(#0003, #fff3);

  --theme-highlight-left: 5.75rem;
}
</style>

<style>

body{
  margin: 0;
  background-color: var(--background);
  color: var(--on-surface);
  font-family: "Noto Sans JP", system-ui;
  font-optical-sizing: auto;
  font-weight: 400;
  font-style: normal;
  scrollbar-gutter: stable;
  min-height: 100dvh;
}

#main-wrapper{
  display: flex;
  flex-direction: row;
  justify-content: baseline;
  align-items: flex-start;
}

#sidebar-wrapper{
  z-index: 2;
  width: 25%;
  height: 100%;
  padding-inline: 15px;
  padding-block-start: 40px;
  background-color: var(--background);
  position: sticky;
  top: -40px;
}

#menu-button{
  position: fixed;
  display: none;
  height: 2.5rem;
  font-size: 1rem;
  background-color: var(--surface-low);
  border: none;
  color: var(--primary);
  height: 50px;
  padding-block: 5px;
  padding-inline: 15px;
  box-sizing: border-box;
  box-shadow: var(--shadow) 0 0 5px;
  border-bottom-right-radius: 10px;
  transition: background-color 0.1s ease-out;
  transition: color 0.1s ease-out;
  svg{
    position: relative;
    top: 0.1rem;
    width: 1rem;
    height: 1rem;
    fill: var(--primary);
    transition: fill 0.1s ease-out;
  }
  &.active{
    background-color: var(--primary-container);
    color: var(--background);
    svg{
      fill: var(--background);
    }
  }
}

#content-wrapper{
  display: flex;
  flex-direction: row;
  gap: 2rem;
  width: calc(75% - 2rem);
  flex-grow: 1;
}

@media (max-width: 785px) {
  #sidebar-wrapper{
    position: fixed;
    left: 0;
    top: 0;
    width: calc(100vw - 30px);
    height: calc(100dvh - 40px);
    transform: translateX(-100vw);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    &.active{
      transform: translateX(0px);
    }
  }

  #menu-button{
    z-index: 2;
    display: block;
  }

  #content-wrapper{
    width: 100%;
  }
}
</style>